<view class="tabbar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="icon-wrap">
      <view class="pill {{selected === index ? 'on' : ''}}"></view>
      <image class="icon" src="{{item.icon}}" mode="aspectFit" />
    </view>
    <view class="label">{{item.text}}</view>
  </view>
</view>
