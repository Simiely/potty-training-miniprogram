.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #F0E4D8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 14rpx;
  position: relative;
  z-index: 1;
  -webkit-tap-highlight-color: transparent;
}
/* 点击反馈：用 hover-class 替代不可靠的 :active（微信 <view> 上 :active 经常不触发） */
.tab-hover { opacity: 0.6; }

/* 选中背景：每个 tab 自带一块半透明圆角底，居中垫在图标后方（紧凑形，
   iPad 宽 tab 下也只包住图标，不会拉成横跨整格的长条） */
.pill {
  position: absolute;
  top: 8rpx;
  left: 50%;
  width: 72rpx;
  height: 72rpx;
  margin-left: -36rpx;
  background: rgba(255, 138, 101, 0.18);
  border-radius: 20rpx;
  opacity: 0;
  transition: opacity 0.18s ease;
  pointer-events: none;
  z-index: 0;
}
.tab.active .pill { opacity: 1; }

.icon-wrap {
  position: relative;
  z-index: 1;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon {
  width: 46rpx;
  height: 46rpx;
  position: relative;
  z-index: 1;
}

.label {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #9E9E9E;
}
.tab.active .label {
  color: #FF8A65;
  font-weight: 600;
}

/* 深色模式：跟随系统，暖色暗调（背景/边框统一用主题变量，与全站一致） */
@media (prefers-color-scheme: dark) {
  .tabbar {
    background: var(--card-bg);
    border-top-color: var(--border);
  }
  .label {
    color: #B0A597;
  }
  .tab.active .label {
    color: #FF8A65;
  }
}

/* 平板 / 大屏：用 px 固定 Tab 栏自身尺寸，避免 rpx 在 iPad 上被放大 */
.tabbar.tablet { padding-bottom: env(safe-area-inset-bottom); }
.tabbar.tablet .tab { padding: 8px 0 10px; }
.tabbar.tablet .icon-wrap { width: 52px; height: 52px; }
.tabbar.tablet .icon { width: 28px; height: 28px; }
.tabbar.tablet .pill { width: 58px; height: 58px; margin-left: -29px; top: 6px; border-radius: 16px; }
.tabbar.tablet .label { font-size: 13px; }
