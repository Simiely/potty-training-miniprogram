.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #F0E4D8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 14rpx;
  position: relative;
  z-index: 1;
  -webkit-tap-highlight-color: transparent;
}
/* 点击反馈：用 hover-class 替代不可靠的 :active（微信 <view> 上 :active 经常不触发） */
.tab-hover { opacity: 0.6; }

/* 选中背景：每个 tab 自带一块半透明圆角底，居中垫在图标后方（紧凑形，
   iPad 宽 tab 下也只包住图标，不会拉成横跨整格的长条） */
.pill {
  position: absolute;
  top: 8rpx;
  left: 50%;
  width: 72rpx;
  height: 72rpx;
  margin-left: -36rpx;
  background: rgba(255, 138, 101, 0.18);
  border-radius: 20rpx;
  opacity: 0;
  transition: opacity 0.18s ease;
  pointer-events: none;
  z-index: 0;
}
.tab.active .pill { opacity: 1; }

.icon-wrap {
  position: relative;
  z-index: 1;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon {
  width: 46rpx;
  height: 46rpx;
  position: relative;
  z-index: 1;
}

.label {
  position: relative;
  z-index: 1;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #9E9E9E;
}
.tab.active .label {
  color: #FF8A65;
  font-weight: 600;
}

/* 深色模式：跟随系统，暖色暗调（背景/边框统一用主题变量，与全站一致） */
@media (prefers-color-scheme: dark) {
  .tabbar {
    background: var(--card-bg);
    border-top-color: var(--border);
  }
  .label {
    color: #B0A597;
  }
  .tab.active .label {
    color: #FF8A65;
  }
}

/* 平板 / 大屏：Dock 风格——3 个 icon 居中聚拢，浮在底部中央（类 macOS 程序坞） */
.tabbar.tablet {
  left: 50%;
  right: auto;
  transform: translateX(-50%);
  width: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  padding-bottom: calc(env(safe-area-inset-bottom) + 8px);
  bottom: calc(env(safe-area-inset-bottom) + 18px);
  /* 磨砂玻璃：半透明暖色底 + 背景模糊；高光描边用浅色边框 + 顶部 inset 高光，模拟 macOS Dock 反光 */
  background: rgba(255, 248, 242, 0.4);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 24px;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.16),
              inset 0 1px 0 rgba(255, 255, 255, 0.7),
              inset 0 0 0 1px rgba(255, 255, 255, 0.25);
}
.tabbar.tablet .tab {
  flex: 0 0 auto;          /* 不拉伸，3 个 icon 并排聚拢居中 */
  padding: 6px 14px 8px;
}
.tabbar.tablet .icon-wrap { width: 52px; height: 52px; }
.tabbar.tablet .icon { width: 28px; height: 28px; }
.tabbar.tablet .pill { width: 58px; height: 58px; margin-left: -29px; top: 6px; border-radius: 16px; }
.tabbar.tablet .label { font-size: 13px; }

/* 深色模式：Dock 磨砂玻璃
   注意：必须与浅色 .tabbar.tablet 同选择器、且写在它【后面】。
   两者特异性相同，@media 不增加特异性，源顺序靠后者胜；若写在前面会被浅色覆盖，
   导致深色模式下 Dock 仍显示浅色。透明度也调高，让磨砂更明显。 */
@media (prefers-color-scheme: dark) {
  .tabbar.tablet {
    background: rgba(34, 27, 22, 0.42);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5),
                inset 0 1px 0 rgba(255, 255, 255, 0.25),
                inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }
}
