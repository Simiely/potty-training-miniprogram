.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #F0E4D8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 14rpx;
  -webkit-tap-highlight-color: transparent;
}
.tab:active { opacity: 0.7; }

.icon-wrap {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon {
  width: 46rpx;
  height: 46rpx;
  position: relative;
  z-index: 2;
}

/* 选中时垫在 emoji 下方的主题色半透明超椭圆 */
.pill {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 60rpx;
  height: 60rpx;
  transform: translate(-50%, -50%) scale(0.5);
  background: rgba(255, 138, 101, 0.20);
  border-radius: 22rpx;
  opacity: 0;
  transition: opacity 0.18s ease, transform 0.24s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 1;
}
.pill.on {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.label {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #9E9E9E;
}
.tab.active .label {
  color: #FF8A65;
  font-weight: 600;
}
