.screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.lock-screen {
  background: var(--lock-bg);
}
.statusbar {
  width: 100%;
}
.lock-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 0;
  width: 100%;
  max-width: 680px;
  margin: 0 auto;
}
.lock-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FF8A65, #FFAB91);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 138, 101, 0.35);
}
.lock-appname {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-top: 24rpx;
}
.lock-prompt {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.auth-btn {
  margin-top: 64rpx;
  background: linear-gradient(135deg, #FF8A65, #FF7043);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 0 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 138, 101, 0.35);
}
.auth-btn::after {
  border: none;
}

.lock-dots {
  display: flex;
  justify-content: center;
  margin-top: 56rpx;
}
.lock-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 4rpx solid #FF8A65;
  background: transparent;
  transition: all 0.15s;
}
.lock-dot + .lock-dot {
  margin-left: 48rpx; /* 点位间距；用 margin 而非 gap，兼容旧基础库 */
}
.lock-dot.filled {
  background: #FF8A65;
}
.lock-dot.error {
  border-color: #E64A19;
  background: #E64A19;
}
.lock-dots.shake {
  animation: shake 0.42s;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-16rpx); }
  40%, 80% { transform: translateX(16rpx); }
}
.lock-error {
  color: #E64A19;
  font-size: 24rpx;
  margin-top: 24rpx;
  min-height: 32rpx;
}

.keypad {
  width: 100%;
  padding: 28rpx 56rpx 48rpx;
  box-sizing: border-box;
  margin-top: 32rpx;
}
.keypad-row {
  display: flex;
  justify-content: center;
  gap: 44rpx; /* 键之间固定间隙，避免被 flex 压缩成紧贴 */
  margin-bottom: 44rpx;
}
.key {
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0; /* 关键：禁止键被 flex 行压缩，否则数字会贴在一起 */
  border-radius: 50%;
  background: var(--key-bg);
  font-size: 52rpx;
  font-weight: 600;
  color: var(--key-text);
  display: flex;
  align-items: center;
  justify-content: center;
}
.key:active {
  background: var(--key-active);
}
.key.empty {
  background: transparent;
}
.key.del {
  background: transparent;
  color: var(--text-muted);
  font-size: 48rpx;
}

.lock-foot {
  padding: 8rpx 0 20rpx;
}
.lock-foot .lk {
  font-size: 24rpx;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.lock-harmony-tip {
  padding: 8rpx 24rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 138, 101, 0.12);
  color: #E64A19;
  font-size: 22rpx;
}

/* ============================================================
   平板 / 大屏（.tablet 由 JS 挂上，px 单位，避免 rpx 在 iPad 上爆掉）
   ============================================================ */
.tablet .lock-body { max-width: 600px; }
.tablet .lock-icon { width: 100px; height: 100px; font-size: 50px; border-radius: 28px; }
.tablet .lock-appname { font-size: 26px; margin-top: 20px; }
.tablet .lock-prompt { font-size: var(--t-fs); }
.tablet .lock-dots { margin-top: 40px; }
.tablet .lock-dot { width: 20px; height: 20px; border-width: 3px; }
.tablet .lock-dot + .lock-dot { margin-left: 32px; }
.tablet .lock-error { font-size: var(--t-fs-sm); }
.tablet .keypad { padding: 28px 0 36px; margin-top: 28px; }
.tablet .keypad-row { gap: 28px; margin-bottom: 28px; }
.tablet .key { width: 88px; height: 88px; font-size: 34px; border-radius: 50%; box-shadow: var(--t-shadow); transition: transform .12s ease; }
.tablet .key:active { transform: scale(0.96); }
.tablet .key.del { font-size: 32px; }
.tablet .lock-foot .lk { font-size: var(--t-fs-sm); }
.tablet .lock-harmony-tip { font-size: var(--t-fs-sm); }
