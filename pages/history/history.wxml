<view class="page">
  <view class="appbar" style="padding-top: {{navHeight}}px;">
    <view class="appbar-title">📋 历史记录</view>
  </view>

  <view wx:if="{{groups.length === 0}}" class="card"><view class="empty-center">📭 暂无记录，开始记录宝宝的如厕情况吧！</view></view>

  <view wx:if="{{groups.length > 0}}" class="card">
    <view class="card-head">
      <view class="title">📋 历史记录</view>
      <view class="clear-all" bindtap="onClearAll">清空全部</view>
    </view>

    <view wx:for="{{groups}}" wx:key="date" class="group">
      <!-- 日期行 -->
      <view class="hist-row {{item.isToday ? 'today' : ''}}" bindtap="toggleDate" data-date="{{item.date}}">
        <view class="hist-left">
          <text class="date">{{item.dateLabel}}</text>
          <text wx:if="{{item.isToday}}" class="today-chip">今天</text>
        </view>
        <view class="hist-right">
          <text wx:if="{{item.poopCount > 0}}" class="mini-chip chip-poop">💩{{item.poopCount}}</text>
          <text wx:if="{{item.peeCount > 0}}" class="mini-chip chip-pee">💧{{item.peeCount}}</text>
          <text wx:if="{{item.underwearCount > 0}}" class="mini-chip chip-underwear">🩲{{item.underwearCount}}</text>
          <text wx:if="{{item.diaperCount > 0}}" class="mini-chip chip-diaper">👶{{item.diaperCount}}</text>
          <text class="arrow">{{expanded[item.date] ? '▾' : '▸'}}</text>
        </view>
      </view>

      <!-- 展开详情 -->
      <view wx:if="{{expanded[item.date]}}" class="hist-detail">
        <view wx:for="{{item.records}}" wx:for-item="rec" wx:key="id" class="hd-item">
          <view class="hd-left">
            <view class="hd-dot" style="background:{{rec.color}}"></view>
            <text class="hd-name">{{rec.emoji}} {{rec.label}}</text>
            <text class="hd-time">{{rec.time}}</text>
            <view wx:if="{{rec.recorder}}" class="hd-recorder">
              <image wx:if="{{rec.recorder.avatarUrl}}" class="hd-avatar" src="{{rec.recorder.avatarUrl}}" mode="aspectFill" />
              <text class="hd-rname">{{rec.recorder.nickname}}</text>
            </view>
          </view>
          <view class="hd-actions">
            <view wx:if="{{rec.canEdit}}" class="hd-edit" catchtap="onEdit" data-id="{{rec.id}}" data-ts="{{rec.timestamp}}">🖊</view>
            <view wx:if="{{rec.canDelete}}" class="hd-del" catchtap="onDelete" data-id="{{rec.id}}">🗑</view>
          </view>
        </view>
      </view>

      <view class="hist-sep"></view>
    </view>
  </view>

  <view style="height:40rpx;"></view>

  <!-- 修改时间弹层 -->
  <view wx:if="{{showEditor}}" class="sheet-mask" bindtap="closeEditor">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">✏️ 修改时间</view>
      <view class="picker-group">
        <view class="picker-label">日期</view>
        <picker mode="date" value="{{editDate}}" bindchange="onDateChange">
          <view class="picker-val">{{editDate || '请选择日期'}}</view>
        </picker>
      </view>
      <view class="picker-group">
        <view class="picker-label">时间</view>
        <picker mode="time" value="{{editTime}}" bindchange="onTimeChange">
          <view class="picker-val">{{editTime || '请选择时间'}}</view>
        </picker>
      </view>
      <view class="editor-actions">
        <view class="ebtn ebtn-cancel" bindtap="closeEditor">取消</view>
        <view class="ebtn ebtn-save" bindtap="saveEdit">保存</view>
      </view>
    </view>
  </view>
</view>
