.page { min-height: 100vh; padding-bottom: 160rpx; }
.appbar {
  background: linear-gradient(135deg, #FF8A65 0%, #FFAB91 100%);
  padding: 0 32rpx 28rpx;
  text-align: center;
}
.appbar-title { font-size: 34rpx; font-weight: 700; color: #fff; }

.empty-center { text-align: center; padding: 64rpx 40rpx; color: var(--text-muted); font-size: 26rpx; }

.clear-all {
  font-size: 24rpx; font-weight: 500; color: var(--danger);
  background: transparent; border: 1rpx solid var(--danger-border); border-radius: 24rpx; padding: 10rpx 22rpx;
}

.group { margin-bottom: 4rpx; }
.hist-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 22rpx; border-radius: 24rpx;
}
.hist-row.today { background: var(--today-bg); }
.hist-row:active { background: var(--active-bg); }
.hist-row.today:active { background: var(--today-active-bg); }
.hist-left { display: flex; align-items: center; gap: 16rpx; }
.hist-left .date { font-size: 28rpx; font-weight: 600; }
.today-chip { font-size: 20rpx; font-weight: 600; color: #fff; background: #42A5F5; padding: 2rpx 14rpx; border-radius: 999rpx; }
.hist-right { display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap; }
.mini-chip { font-size: 20rpx; font-weight: 600; padding: 4rpx 14rpx; border-radius: 999rpx; }
.chip-pee { background: var(--stat-pee-bg); color: var(--stat-pee-text); }
.chip-poop { background: var(--stat-poop-bg); color: var(--stat-poop-text); }
.chip-underwear { background: var(--stat-underwear-bg); color: var(--stat-underwear-text); }
.chip-diaper { background: var(--stat-diaper-bg); color: var(--stat-diaper-text); }
.arrow { color: var(--icon-muted); font-size: 28rpx; }

.hist-detail { padding: 4rpx 16rpx 16rpx 24rpx; }
.hd-item { display: flex; align-items: center; justify-content: space-between; padding: 16rpx; }
.hd-left { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.hd-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.hd-name { font-size: 26rpx; font-weight: 500; }
.hd-time { font-size: 22rpx; color: var(--text-muted); }
.hd-recorder { display: flex; align-items: center; gap: 8rpx; margin-left: 8rpx; padding-left: 16rpx; border-left: 1rpx solid var(--border); }
.hd-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; border: 2rpx solid var(--border); }
.hd-rname { font-size: 22rpx; color: var(--text-muted); }
.hd-del { color: var(--icon-muted); font-size: 32rpx; padding: 0 10rpx; }
.hd-del:active { color: var(--danger); }

.hist-sep { height: 1rpx; background: var(--border); margin-top: 16rpx; }
