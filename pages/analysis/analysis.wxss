.page { min-height: 100vh; padding-bottom: 160rpx; }
.appbar {
  background: linear-gradient(135deg, #FF8A65 0%, #FFAB91 100%);
  padding: 0 32rpx 28rpx;
  text-align: center;
}
.appbar-title { font-size: 34rpx; font-weight: 700; color: #fff; }

.section-label { font-size: 26rpx; font-weight: 600; margin-bottom: 16rpx; display: flex; align-items: baseline; justify-content: space-between; }
.sec-sub { font-size: 22rpx; font-weight: 400; color: var(--text-muted); }

.trend-box { padding: 24rpx; border-radius: 24rpx; background: var(--trend-bg); margin-bottom: 28rpx; }
.trend-desc { font-size: 24rpx; color: var(--text-muted); margin-bottom: 20rpx; }
.trend-bars { display: flex; align-items: flex-end; gap: 10rpx; height: 92rpx; }
.trend-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.trend-col .bv { font-size: 20rpx; color: var(--text-muted); margin-bottom: 4rpx; }
.trend-col .bh { width: 100%; background: #42A5F5; border-radius: 8rpx 8rpx 0 0; min-height: 8rpx; }

.chips { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 28rpx; }
.chip { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; font-weight: 500; padding: 16rpx 22rpx; border-radius: 16rpx; background: var(--chip-bg); color: var(--chip-text); }
.chip.hot { background: var(--chip-hot-bg); }
.chip-ico { font-size: 24rpx; }
.chip-time { font-weight: 600; }
.chip-count { margin-left: auto; font-size: 22rpx; color: var(--text-muted); }

/* 近7天：每天一张卡片，卡内横向条形 */
.day-cards { display: flex; flex-direction: column; gap: 16rpx; }
/* 底部「近7天明细」独立卡片 */
.an-detail { margin-top: 24rpx; }
.day-card { background: var(--trend-bg); border-radius: 20rpx; padding: 20rpx 24rpx; }
.dc-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14rpx; }
.dc-date { font-size: 24rpx; font-weight: 600; color: var(--text-main); }
.dc-total { font-size: 20rpx; color: var(--text-muted); }
/* 4 类横排：数值 + 名称，emoji 作 10% 透明水印垫在中间 */
.dc-types { display: flex; gap: 12rpx; }
.dc-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 0;
  border-radius: 14rpx;
  overflow: hidden;
}
.dc-item-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 96rpx;
  line-height: 1;
  opacity: 0.02;
  pointer-events: none;
}
.dc-item-val { position: relative; font-size: 46rpx; font-weight: 800; line-height: 1.1; }
.dc-item-name { position: relative; font-size: 24rpx; }
/* 方块配色跟随深浅模式：底色/文字色由 app.wxss 的 --dc-* 变量驱动 */
.dc-item--pee { background: var(--dc-pee-bg); color: var(--dc-pee-text); }
.dc-item--poop { background: var(--dc-poop-bg); color: var(--dc-poop-text); }
.dc-item--underwear { background: var(--dc-underwear-bg); color: var(--dc-underwear-text); }
.dc-item--diaper { background: var(--dc-diaper-bg); color: var(--dc-diaper-text); }

.empty-center { text-align: center; padding: 40rpx; color: var(--text-muted); font-size: 24rpx; }

/* 顶部 KPI 行（项 3） */
.kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-bottom: 24rpx; }
.kpi-card { background: var(--card-bg); border-radius: 20rpx; padding: 20rpx 24rpx; box-shadow: var(--card-shadow); border: 1rpx solid var(--border); }
.kpi-val { font-size: 40rpx; font-weight: 800; color: var(--text-main); line-height: 1.1; }
.kpi-val--sm { font-size: 26rpx; font-weight: 700; padding-top: 6rpx; }
.kpi-label { font-size: 22rpx; color: var(--text-muted); margin-top: 6rpx; font-weight: 600; }

/* 近7天×4类堆叠柱状图（项 4） */
.stack-chart { display: flex; align-items: flex-end; gap: 10rpx; height: 220rpx; padding: 8rpx 0; }
.stack-col { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stack-bars { display: flex; flex-direction: column-reverse; width: 100%; height: 180rpx; gap: 2rpx; }
.stack-seg { width: 100%; border-radius: 6rpx 6rpx 0 0; min-height: 4rpx; }
.seg--pee { background: #29B6F6; } .seg--poop { background: #8D6E63; }
.seg--under { background: #66BB6A; } .seg--diaper { background: #9575CD; }
.stack-wd { font-size: 20rpx; color: var(--text-muted); margin-top: 8rpx; }
.stack-dt { font-size: 18rpx; color: var(--text-muted); }
.stack-legend { display: flex; gap: 18rpx; margin-top: 16rpx; flex-wrap: wrap; }
.leg { display: flex; align-items: center; gap: 6rpx; font-size: 20rpx; color: var(--text-muted); }
.leg-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.leg--pee { background: #29B6F6; } .leg--poop { background: #8D6E63; }
.leg--under { background: #66BB6A; } .leg--diaper { background: #9575CD; }

/* ============================================================
   平板 / 大屏（.tablet 由 JS 挂上，px 单位，双栏仪表盘）
   ============================================================ */
.tablet .an-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--t-gap);
  align-items: start;
}
.tablet .card { margin: 0; }
.tablet .an-col { padding: var(--t-pad); }
.tablet .section-label { font-size: var(--t-fs-lg); margin-bottom: 14px; }
.tablet .sec-sub { font-size: var(--t-fs-sm); }
.tablet .trend-box { padding: 20px; margin-bottom: 22px; border-radius: var(--t-radius); }
.tablet .trend-desc { font-size: var(--t-fs); margin-bottom: 16px; }
.tablet .trend-bars { height: 140px; gap: 14px; }
.tablet .trend-col .bv { font-size: var(--t-fs-sm); }
.tablet .trend-col .bh { border-radius: 8px 8px 0 0; }
.tablet .chips { display: flex; flex-direction: column; gap: 12px; margin-bottom: 22px; }
.tablet .chip {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 18px; border-radius: var(--t-radius);
  font-size: var(--t-fs); font-weight: 600; color: var(--text-main);
  background: var(--card-bg); border: 1rpx solid var(--border);
}
.tablet .chip.hot { background: var(--chip-hot-bg); color: var(--chip-text); border-color: transparent; }
.tablet .chip-ico { font-size: var(--t-fs); }
.tablet .chip-time { font-size: var(--t-fs); }
.tablet .chip-count { margin-left: auto; font-size: var(--t-fs-sm); color: var(--text-muted); }
.tablet .chip.hot .chip-count { color: var(--chip-text); }
.tablet .day-cards { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: var(--t-gap-sm); }
.tablet .an-detail { margin-top: var(--t-gap); }
.tablet .day-card { min-width: 0; overflow: hidden; padding: 16px 16px; border-radius: var(--t-radius); }
.tablet .dc-head { margin-bottom: 10px; }
.tablet .dc-date { font-size: var(--t-fs); }
.tablet .dc-total { font-size: var(--t-fs-sm); }
/* 卡内 4 类改为竖向堆叠行（窄列下不再横向挤压溢出） */
.tablet .dc-types { flex-direction: column; gap: 6px; }
.tablet .dc-item { display: flex; flex-direction: row; align-items: center; justify-content: flex-start; gap: 8px; padding: 7px 10px; border-radius: var(--t-radius); text-align: left; }
.tablet .dc-item-val { font-size: 16px; }
.tablet .dc-item-name { font-size: 12px; }
.tablet .empty-center { font-size: var(--t-fs); padding: 24px; }

.tablet .kpi-row { grid-template-columns: repeat(3, 1fr); gap: var(--t-gap); margin-bottom: 22px; }
.tablet .kpi-card { border-radius: var(--t-radius); padding: 20px 24px; }
.tablet .kpi-val { font-size: 38px; }
.tablet .kpi-val--sm { font-size: 22px; padding-top: 6px; }
.tablet .kpi-label { font-size: var(--t-fs); margin-top: 6px; }
.tablet .stack-chart { gap: 14px; height: 240px; padding: 8px 0; }
.tablet .stack-bars { height: 200px; gap: 2px; }
.tablet .stack-wd { font-size: var(--t-fs-sm); margin-top: 8px; }
.tablet .stack-dt { font-size: 12px; }
.tablet .stack-legend { gap: 18px; margin-top: 16px; }
.tablet .leg { font-size: var(--t-fs-sm); }
.tablet .leg-dot { width: 14px; height: 14px; border-radius: 4px; }

/* 近7天方块 emoji 水印：窄列卡内不放大水印，避免视觉干扰 */
.tablet .dc-item-bg { display: none; }
