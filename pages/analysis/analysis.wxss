.page { min-height: 100vh; padding-bottom: 160rpx; }
.appbar {
  background: linear-gradient(135deg, #FF8A65 0%, #FFAB91 100%);
  padding: 0 32rpx 28rpx;
  text-align: center;
}
.appbar-title { font-size: 34rpx; font-weight: 700; color: #fff; }

.section-label { font-size: 26rpx; font-weight: 600; margin-bottom: 16rpx; }

.trend-box { padding: 24rpx; border-radius: 24rpx; background: var(--trend-bg); margin-bottom: 28rpx; }
.trend-desc { font-size: 24rpx; color: var(--text-muted); margin-bottom: 20rpx; }
.trend-bars { display: flex; align-items: flex-end; gap: 10rpx; height: 92rpx; }
.trend-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.trend-col .bv { font-size: 20rpx; color: var(--text-muted); margin-bottom: 4rpx; }
.trend-col .bh { width: 100%; background: #42A5F5; border-radius: 8rpx 8rpx 0 0; min-height: 8rpx; }

.chips { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 28rpx; }
.chip { font-size: 24rpx; font-weight: 500; padding: 10rpx 22rpx; border-radius: 999rpx; background: var(--chip-bg); color: var(--chip-text); }
.chip.hot { background: var(--chip-hot-bg); }

.legend { display: flex; gap: 28rpx; flex-wrap: wrap; margin-bottom: 16rpx; }
.legend .li { display: flex; align-items: center; gap: 10rpx; font-size: 22rpx; color: var(--text-muted); }
.legend .dot { width: 18rpx; height: 18rpx; border-radius: 50%; }

.chart { display: flex; align-items: flex-end; gap: 10rpx; height: 160rpx; margin-bottom: 16rpx; }
.day { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
.day .bar { width: 100%; border-radius: 4rpx 4rpx 0 0; min-height: 4rpx; }
.day .dl { font-size: 20rpx; color: var(--text-muted); margin-top: 8rpx; }

.chart-data { display: flex; gap: 10rpx; }
.chart-data .col { flex: 1; text-align: center; font-size: 20rpx; line-height: 1.5; color: var(--text-muted); }

.empty-center { text-align: center; padding: 40rpx; color: var(--text-muted); font-size: 24rpx; }
