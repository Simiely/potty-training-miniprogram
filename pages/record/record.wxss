.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}
.appbar {
  background: linear-gradient(135deg, #FF8A65 0%, #FFAB91 100%);
  padding: 0 32rpx 28rpx;
  text-align: center;
}
.appbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5px;
}

/* 当前记录人胶囊 */
.recorder-bar {
  display: flex; align-items: center; gap: 18rpx;
  margin: 24rpx 24rpx 0;
  padding: 18rpx 24rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  box-shadow: var(--card-shadow);
}
.recorder-bar:active { opacity: 0.92; }
.rec-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  border: 2rpx solid var(--border);
  background: var(--trend-bg);
}
.rec-avatar-empty {
  display: flex; align-items: center; justify-content: center;
  font-size: 34rpx;
}
.rec-text { flex: 1; display: flex; flex-direction: column; }
.rec-label { font-size: 20rpx; color: var(--text-muted); }
.rec-name { font-size: 30rpx; font-weight: 700; color: var(--text-main); }
.rec-caret { font-size: 24rpx; color: var(--text-muted); white-space: nowrap; }

.record-grid { padding: 24rpx 24rpx 0; display: grid; grid-template-columns: 1fr 1fr; gap: 22rpx; }
.rec-btn {
  padding: 36rpx 0;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}
/* 点击反馈：用 hover-class 替代不可靠的 :active（微信 <view> 上 :active 经常不触发） */
.rec-hover { opacity: 0.9; transform: scale(0.97); }
/* 撤销按钮：悬浮在最上层、位于底部 TabBar 上方，不挤压页面布局 */
.undo-fab {
  position: fixed;
  left: 50%;
  bottom: calc(130rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: #FF8A65;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 101, 0.45);
  animation: undoIn 0.25s ease;
}
.undo-fab:active { background: #FB7B4B; }
@keyframes undoIn {
  from { opacity: 0; transform: translate(-50%, 20rpx); }
  to { opacity: 1; transform: translate(-50%, 0); }
}

/* 今日 KPI 统计 */
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22rpx; margin: 24rpx 24rpx 0; }
.stat-box { text-align: center; padding: 26rpx; border-radius: 28rpx; }
.stat-box.pee { background: var(--stat-pee-bg); }
.stat-box.pee .num { color: var(--stat-pee-text); }
.stat-box.poop { background: var(--stat-poop-bg); }
.stat-box.poop .num { color: var(--stat-poop-text); }
.stat-box.underwear { background: var(--stat-underwear-bg); }
.stat-box.underwear .num { color: var(--stat-underwear-text); }
.stat-box.diaper { background: var(--stat-diaper-bg); }
.stat-box.diaper .num { color: var(--stat-diaper-text); }
.stat-box .num { font-size: 56rpx; font-weight: 700; line-height: 1.1; }
.stat-box .lbl { font-size: 24rpx; color: var(--text-muted); margin-top: 4rpx; }

.empty-center { text-align: center; padding: 20rpx 32rpx; color: var(--text-muted); font-size: 26rpx; line-height: 1.6; }

/* 时间线 */
.tl-divider {
  display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx;
  color: var(--text-muted); font-size: 24rpx;
}
.tl-divider::before, .tl-divider::after { content: ''; flex: 1; height: 1rpx; background: var(--border); }
.timeline { position: relative; padding-left: 32rpx; }
.tl-item { position: relative; padding-bottom: 24rpx; }
.tl-item:last-child { padding-bottom: 0; }
.tl-item::before {
  content: ''; position: absolute; left: -26rpx; top: 10rpx;
  width: 20rpx; height: 20rpx; border-radius: 50%; z-index: 1;
}
.tl-item:not(:last-child)::after {
  content: ''; position: absolute; left: -16rpx; top: 30rpx;
  width: 4rpx; height: calc(100% - 8rpx); background: #FFE0B2;
}
.t-pee::before { background: #42A5F5; }
.t-poop::before { background: #FF7043; }
.t-underwear::before { background: #66BB6A; }
.t-diaper::before { background: #BA68C8; }
.tl-line { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.tl-line .name { font-size: 26rpx; font-weight: 600; min-width: 180rpx; }
.tl-line .time { font-size: 22rpx; color: var(--text-muted); }
.tl-recorder { display: flex; align-items: center; gap: 8rpx; margin-left: auto; }
.tl-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; border: 2rpx solid var(--border); }
.tl-rname { font-size: 22rpx; color: var(--text-muted); }

/* 底部弹层（选择记录人 / 编辑照顾者） */
.sheet-mask {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: flex-end;
}
.sheet {
  width: 100%;
  background: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
}
.sheet-title { font-size: 32rpx; font-weight: 700; color: var(--text-main); text-align: center; margin-bottom: 24rpx; }
.sheet-empty { text-align: center; color: var(--text-muted); font-size: 26rpx; padding: 24rpx 0; }
.profile-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 22rpx; border-radius: 24rpx; margin-bottom: 16rpx;
  background: var(--trend-bg);
}
.profile-item:active { opacity: 0.9; }
.profile-item.add { justify-content: center; color: var(--text-muted); font-weight: 600; }
.pi-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; border: 2rpx solid var(--border); }
.pi-empty { display: flex; align-items: center; justify-content: center; font-size: 40rpx; background: var(--card-bg); }
.pi-name { flex: 1; font-size: 30rpx; font-weight: 600; color: var(--text-main); }
.pi-check { font-size: 24rpx; color: #388E3C; font-weight: 600; }
.pi-del { font-size: 36rpx; color: var(--icon-muted); padding: 0 10rpx; }
.pi-del:active { color: var(--danger); }
.sheet-cancel {
  text-align: center; margin-top: 8rpx; padding: 24rpx;
  font-size: 30rpx; color: var(--text-muted); font-weight: 600;
  background: var(--trend-bg); border-radius: 24rpx;
}

/* 照顾者编辑表单 */
.avatar-btn {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  background: var(--trend-bg); border-radius: 24rpx; padding: 40rpx 0; margin-bottom: 28rpx;
}
.avatar-btn::after { border: none; }
.edit-avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 2rpx solid var(--border); }
.edit-avatar-empty { display: flex; align-items: center; justify-content: center; font-size: 72rpx; background: var(--card-bg); }
.avatar-tip { font-size: 24rpx; color: var(--text-muted); }
.nick-input {
  background: var(--trend-bg); border-radius: 20rpx; padding: 26rpx 28rpx;
  font-size: 30rpx; color: var(--text-main); margin-bottom: 32rpx;
}
.nick-ph { color: var(--icon-muted); }
.editor-actions { display: flex; gap: 22rpx; }
.ebtn { flex: 1; text-align: center; padding: 26rpx 0; border-radius: 999rpx; font-size: 30rpx; font-weight: 700; }
.ebtn-cancel { background: var(--trend-bg); color: var(--text-muted); }
.ebtn-save { background: #FF8A65; color: #fff; }
.ebtn-save:active { background: #FB7B4B; }

/* 预测面板 */
.pred-window {
  text-align: center; padding: 28rpx; border-radius: 28rpx; margin-bottom: 28rpx;
}
.pred-window.conf-high { background: var(--conf-high-bg); border: 4rpx solid var(--conf-high-border); }
.pred-window.conf-medium { background: var(--conf-medium-bg); border: 4rpx solid var(--conf-medium-border); }
.pred-window.conf-low { background: var(--conf-low-bg); border: 4rpx solid var(--conf-low-border); }
.pred-window .hint { font-size: 24rpx; color: var(--text-muted); margin-bottom: 10rpx; }
.pred-window .range { font-size: 30rpx; font-weight: 700; }
.pred-stats { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.pred-stat { flex: 1; text-align: center; padding: 18rpx; border-radius: 24rpx; background: var(--trend-bg); }
.pred-stat .v { font-size: 40rpx; font-weight: 700; }
.pred-stat .v.muted { color: var(--text-muted); }
.pred-stat .k { font-size: 22rpx; color: var(--text-muted); }
.confidence { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 26rpx; border-radius: 24rpx; }
.confidence.conf-high { background: var(--conf-high-bg); }
.confidence.conf-medium { background: var(--conf-medium-bg); }
.confidence.conf-low { background: var(--conf-low-bg); }
.conf-chip { font-size: 22rpx; font-weight: 600; color: #fff; background: #66BB6A; padding: 8rpx 18rpx; border-radius: 999rpx; white-space: nowrap; }
.confidence .desc { font-size: 22rpx; color: var(--text-muted); }
.prog { height: 16rpx; background: var(--prog-bg); border-radius: 999rpx; margin-top: 32rpx; overflow: hidden; }
.prog-bar { height: 100%; background: #FF8A65; border-radius: 999rpx; }

/* ============================================================
   平板 / 大屏（.tablet 由 JS 依据 screenWidth 挂上，px 单位，仪表盘）
   ============================================================ */
/* 大屏下「当前记录人」条：用 px 固定尺寸（平板无左侧栏，此处保留作为切换入口） */
.tablet .recorder-bar {
  display: flex;
  margin: 20px 0 0;
  padding: 14px 18px;
  border-radius: 16px;
}
.tablet .rec-avatar { width: 44px; height: 44px; }
.tablet .rec-avatar-empty { font-size: 22px; }
.tablet .rec-label { font-size: 12px; }
.tablet .rec-name { font-size: 16px; }
.tablet .rec-caret { font-size: 14px; }
.tablet .record-grid { padding: 20px 0 0; grid-template-columns: repeat(4, 1fr); gap: var(--t-gap); }
.tablet .rec-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;
  padding: 24px 0; border-radius: var(--t-radius-lg);
  font-size: var(--t-fs); font-weight: 600; color: #fff; text-align: center;
  box-shadow: var(--t-shadow);
  transition: transform .15s ease, box-shadow .15s ease;
}
.tablet .rec-btn .rb-ico { font-size: 30px; line-height: 1; }
.tablet .rec-btn .rb-lbl { font-size: var(--t-fs); }
.tablet .rec-btn:hover { transform: translateY(-3px); box-shadow: var(--t-shadow-lg); }
.tablet .rec-hover { transform: scale(0.97); box-shadow: var(--t-shadow); }
.tablet .undo-fab { bottom: calc(100px + env(safe-area-inset-bottom)); font-size: var(--t-fs-sm); padding: 14px 28px; }
.tablet .stat-grid { grid-template-columns: repeat(4, 1fr); gap: var(--t-gap); margin: 20px 0 0; }
.tablet .stat-box { padding: 18px; border-radius: var(--t-radius-lg); display: flex; flex-direction: column; align-items: center; gap: 4px; }
.tablet .stat-box .num { font-size: var(--t-num); }
.tablet .stat-box .lbl { font-size: var(--t-fs-sm); }
.tablet .rec-main .card-head .title { font-size: 15px; }
.tablet .rec-main {
  display: grid;
  grid-template-columns: 1.25fr 1fr;
  gap: var(--t-gap);
  align-items: start;
  margin-top: 20px;
}
.tablet .card { margin: 0; }
.tablet .pred-window { padding: 22px; margin-bottom: 18px; border-width: 2px; border-radius: var(--t-radius); }
.tablet .pred-window .range { font-size: var(--t-fs-lg); }
.tablet .pred-stats { gap: var(--t-gap-sm); margin-bottom: 18px; }
.tablet .pred-stat { padding: 14px; border-radius: var(--t-radius); }
.tablet .pred-stat .v { font-size: 26px; }
.tablet .pred-stat .k { font-size: var(--t-fs-sm); }
.tablet .confidence { padding: 16px 18px; gap: 12px; border-radius: var(--t-radius); }
.tablet .conf-chip { font-size: var(--t-fs-sm); padding: 6px 14px; }
.tablet .confidence .desc { font-size: var(--t-fs-sm); }
.tablet .tl-divider { font-size: 12px; margin-bottom: 16px; }
.tablet .timeline { padding-left: 24px; }
.tablet .tl-line .name { font-size: var(--t-fs); }
.tablet .tl-line .time { font-size: var(--t-fs-sm); }
.tablet .tl-rname { font-size: 12px; }
.tablet .empty-center { font-size: var(--t-fs); padding: 16px 24px; }
.tablet .prog { margin-top: 20px; }

/* 平板底部弹层（切换记录人 / 编辑照顾者）也用 px，避免 rpx 在 iPad 被放大 */
.tablet .sheet-title { font-size: 18px; margin-bottom: 16px; }
.tablet .sheet-empty { font-size: 14px; padding: 16px 0; }
.tablet .profile-item { gap: 12px; padding: 14px; border-radius: 14px; margin-bottom: 10px; }
.tablet .pi-avatar { width: 46px; height: 46px; }
.tablet .pi-empty { font-size: 26px; }
.tablet .pi-name { font-size: 18px; }
.tablet .pi-check { font-size: 15px; }
.tablet .pi-del { font-size: 22px; }
.tablet .sheet-cancel { padding: 14px; font-size: 18px; border-radius: 14px; }
.tablet .avatar-btn { gap: 8px; border-radius: 14px; padding: 24px 0; margin-bottom: 18px; }
.tablet .edit-avatar { width: 88px; height: 88px; }
.tablet .edit-avatar-empty { font-size: 44px; }
.tablet .avatar-tip { font-size: 14px; }
.tablet .nick-input { border-radius: 12px; padding: 16px 18px; font-size: 18px; margin-bottom: 20px; }
.tablet .editor-actions { gap: 14px; }
.tablet .ebtn { padding: 16px 0; border-radius: 999px; font-size: 18px; }
