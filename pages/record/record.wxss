.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}
.appbar {
  background: linear-gradient(135deg, #FF8A65 0%, #FFAB91 100%);
  padding: 0 32rpx 28rpx;
  text-align: center;
}
.appbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5px;
}

/* 快速记录 */
.record-grid { padding: 24rpx 24rpx 0; display: flex; flex-direction: column; gap: 22rpx; }
.record-row { display: flex; gap: 22rpx; }
.rec-btn {
  flex: 1;
  padding: 36rpx 0;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}
.rec-btn:active { opacity: 0.92; }
/* 撤销按钮：悬浮在最上层、位于底部 TabBar 上方，不挤压页面布局 */
.undo-fab {
  position: fixed;
  left: 50%;
  bottom: calc(130rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  background: #FF8A65;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 101, 0.45);
  animation: undoIn 0.25s ease;
}
.undo-fab:active { background: #FB7B4B; }
@keyframes undoIn {
  from { opacity: 0; transform: translate(-50%, 20rpx); }
  to { opacity: 1; transform: translate(-50%, 0); }
}

/* 今日统计 */
.stat-grid { display: flex; flex-direction: column; gap: 22rpx; margin-bottom: 24rpx; }
.stat-row { display: flex; gap: 22rpx; }
.stat-box { flex: 1; text-align: center; padding: 26rpx; border-radius: 28rpx; }
.stat-box.pee { background: var(--stat-pee-bg); }
.stat-box.pee .num { color: var(--stat-pee-text); }
.stat-box.poop { background: var(--stat-poop-bg); }
.stat-box.poop .num { color: var(--stat-poop-text); }
.stat-box.underwear { background: var(--stat-underwear-bg); }
.stat-box.underwear .num { color: var(--stat-underwear-text); }
.stat-box.diaper { background: var(--stat-diaper-bg); }
.stat-box.diaper .num { color: var(--stat-diaper-text); }
.stat-box .num { font-size: 56rpx; font-weight: 700; line-height: 1.1; }
.stat-box .lbl { font-size: 24rpx; color: var(--text-muted); margin-top: 4rpx; }

.empty-center { text-align: center; padding: 64rpx 40rpx; color: var(--text-muted); font-size: 26rpx; line-height: 1.8; }

/* 时间线 */
.tl-divider {
  display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx;
  color: var(--text-muted); font-size: 24rpx;
}
.tl-divider::before, .tl-divider::after { content: ''; flex: 1; height: 1rpx; background: var(--border); }
.timeline { position: relative; padding-left: 32rpx; }
.tl-item { position: relative; padding-bottom: 24rpx; }
.tl-item:last-child { padding-bottom: 0; }
.tl-item::before {
  content: ''; position: absolute; left: -26rpx; top: 10rpx;
  width: 20rpx; height: 20rpx; border-radius: 50%; z-index: 1;
}
.tl-item:not(:last-child)::after {
  content: ''; position: absolute; left: -16rpx; top: 30rpx;
  width: 4rpx; height: calc(100% - 8rpx); background: #FFE0B2;
}
.t-pee::before { background: #42A5F5; }
.t-poop::before { background: #FF7043; }
.t-underwear::before { background: #66BB6A; }
.t-diaper::before { background: #BA68C8; }
.tl-line { display: flex; align-items: center; gap: 16rpx; }
.tl-line .name { font-size: 26rpx; font-weight: 600; }
.tl-line .time { font-size: 22rpx; color: var(--text-muted); }

/* 预测面板 */
.pred-window {
  text-align: center; padding: 28rpx; border-radius: 28rpx; margin-bottom: 28rpx;
}
.pred-window.conf-high { background: var(--conf-high-bg); border: 4rpx solid var(--conf-high-border); }
.pred-window.conf-medium { background: var(--conf-medium-bg); border: 4rpx solid var(--conf-medium-border); }
.pred-window.conf-low { background: var(--conf-low-bg); border: 4rpx solid var(--conf-low-border); }
.pred-window .hint { font-size: 24rpx; color: var(--text-muted); margin-bottom: 10rpx; }
.pred-window .range { font-size: 30rpx; font-weight: 700; }
.pred-stats { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.pred-stat { flex: 1; text-align: center; padding: 18rpx; border-radius: 24rpx; background: var(--trend-bg); }
.pred-stat .v { font-size: 40rpx; font-weight: 700; }
.pred-stat .v.muted { color: var(--text-muted); }
.pred-stat .k { font-size: 22rpx; color: var(--text-muted); }
.confidence { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 26rpx; border-radius: 24rpx; }
.confidence.conf-high { background: var(--conf-high-bg); }
.confidence.conf-medium { background: var(--conf-medium-bg); }
.confidence.conf-low { background: var(--conf-low-bg); }
.conf-chip { font-size: 22rpx; font-weight: 600; color: #fff; background: #66BB6A; padding: 8rpx 18rpx; border-radius: 999rpx; white-space: nowrap; }
.confidence .desc { font-size: 22rpx; color: var(--text-muted); }

.prog { height: 16rpx; background: var(--prog-bg); border-radius: 999rpx; margin-top: 32rpx; overflow: hidden; }
.prog-bar { height: 100%; background: #FF8A65; border-radius: 999rpx; }
