<view class="page">
  <!-- 自定义渐变导航栏 -->
  <view class="appbar" style="padding-top: {{navHeight}}px;">
    <view class="appbar-title">🚽 宝宝如厕训练助手</view>
  </view>

  <!-- 当前记录人 -->
  <view class="recorder-bar" bindtap="openManager">
    <image wx:if="{{recorder.avatarUrl}}" class="rec-avatar" src="{{recorder.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="rec-avatar rec-avatar-empty">👤</view>
    <view class="rec-text">
      <text class="rec-label">当前记录人</text>
      <text class="rec-name">{{recorder.nickname || '未设置'}}</text>
    </view>
    <text class="rec-caret">切换 ▾</text>
  </view>

  <!-- 快速记录 -->
  <view class="record-grid">
    <view class="record-row">
      <view class="rec-btn grad-pee" bindtap="onRecord" data-type="pee">小便 💧</view>
      <view class="rec-btn grad-poop" bindtap="onRecord" data-type="poop">大便 💩</view>
    </view>
    <view class="record-row">
      <view class="rec-btn grad-underwear" bindtap="onRecord" data-type="underwear">换小内裤 🩲</view>
      <view class="rec-btn grad-diaper" bindtap="onRecord" data-type="diaper">换尿不湿 👶</view>
    </view>
  </view>
  <view wx:if="{{undoVisible}}" class="undo-fab" bindtap="onUndo">↩️ 撤销刚才的记录</view>

  <!-- 今日统计 -->
  <view class="card">
    <view class="card-head">
      <view class="title">📊 今日统计</view>
      <view class="sub">{{todayLabel}}</view>
    </view>
      <view class="stat-grid">
        <view class="stat-row">
          <view class="stat-box pee"><view class="num">{{stats.pee}}</view><view class="lbl">💧 小便</view></view>
          <view class="stat-box poop"><view class="num">{{stats.poop}}</view><view class="lbl">💩 大便</view></view>
        </view>
        <view class="stat-row">
          <view class="stat-box underwear"><view class="num">{{stats.underwear}}</view><view class="lbl">🩲 换小内裤</view></view>
          <view class="stat-box diaper"><view class="num">{{stats.diaper}}</view><view class="lbl">👶 换尿不湿</view></view>
        </view>
      </view>

    <block wx:if="{{timeline.length === 0}}">
      <view class="empty-center">🍼 今天还没有记录哦，点击上方按钮开始记录吧！</view>
    </block>
    <block wx:else>
      <view class="tl-divider">今日时间线</view>
      <view class="timeline">
        <view wx:for="{{timeline}}" wx:key="id" class="tl-item t-{{item.type}}">
          <view class="tl-line">
            <text class="name">{{item.emoji}} {{item.label}}</text>
            <text class="time">{{item.time}}</text>
            <view wx:if="{{item.recorder}}" class="tl-recorder">
              <image wx:if="{{item.recorder.avatarUrl}}" class="tl-avatar" src="{{item.recorder.avatarUrl}}" mode="aspectFill" />
              <text class="tl-rname">{{item.recorder.nickname}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 预测面板 -->
  <view class="card">
    <view class="title" style="margin-bottom:24rpx;">🔮 预测面板</view>

    <block wx:if="{{!prediction.hasEnough}}">
      <view class="empty-center">📝 至少需要记录 2 次大便才能进行预测
        <view style="margin-top:16rpx;font-size:24rpx;">当前已记录 {{prediction.sampleSize}} 次</view>
        <view class="prog"><view class="prog-bar" style="width:{{prediction.sampleSize / 2 * 100}}%"></view></view>
      </view>
    </block>

    <block wx:else>
      <view class="pred-window conf-{{prediction.confidence}}">
        <view class="hint">
          <block wx:if="{{prediction.windowState === 'active'}}">🚨 现在是排便时间窗口！</block>
          <block wx:elif="{{prediction.windowState === 'passed'}}">⏰ 预测窗口已过，请留意宝宝状态</block>
          <block wx:else>预计下次排便时间</block>
        </view>
        <view class="range">{{prediction.windowStart}} ~ {{prediction.windowEnd}}</view>
      </view>
      <view class="pred-stats">
        <view class="pred-stat"><view class="v" style="color:#FF8A65">{{prediction.avgHours}}h</view><view class="k">平均间隔</view></view>
        <view class="pred-stat"><view class="v" style="color:#FFAB91">±{{prediction.stdDevHours}}h</view><view class="k">标准差</view></view>
        <view class="pred-stat"><view class="v muted">{{prediction.sampleSize}}</view><view class="k">样本数</view></view>
      </view>
      <view class="confidence conf-{{prediction.confidence}}">
        <view class="conf-chip">{{prediction.confLabel}}</view>
        <view class="desc">{{prediction.confDesc}}</view>
      </view>
    </block>
  </view>

  <view style="height:40rpx;"></view>

  <!-- 选择记录人面板 -->
  <view wx:if="{{showManager}}" class="sheet-mask" bindtap="closeManager">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">选择记录人</view>
      <view wx:if="{{profiles.length === 0}}" class="sheet-empty">还没有照顾者，点击下方添加</view>
      <view wx:for="{{profiles}}" wx:key="id" class="profile-item" bindtap="selectRecorder" data-id="{{item.id}}">
        <image wx:if="{{item.avatarUrl}}" class="pi-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="pi-avatar pi-empty">👤</view>
        <text class="pi-name">{{item.nickname}}</text>
        <text wx:if="{{item.id === currentUserId}}" class="pi-check">✓ 当前</text>
        <text class="pi-del" catchtap="removeProfile" data-id="{{item.id}}">🗑</text>
      </view>
      <view class="profile-item add" bindtap="openEditor">＋ 添加照顾者</view>
      <view class="sheet-cancel" bindtap="closeManager">取消</view>
    </view>
  </view>

  <!-- 新增/编辑照顾者 -->
  <view wx:if="{{showEditor}}" class="sheet-mask" bindtap="closeEditor">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">{{editId ? '编辑照顾者' : '添加照顾者'}}</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{editAvatar}}" class="edit-avatar" src="{{editAvatar}}" mode="aspectFill" />
        <view wx:else class="edit-avatar edit-avatar-empty">👤</view>
        <text class="avatar-tip">点击选择头像</text>
      </button>
      <input class="nick-input" type="nickname" placeholder="点击获取微信昵称或输入" placeholder-class="nick-ph" value="{{editNickname}}" bindinput="onNickInput" bindblur="onNickInput" />
      <view class="editor-actions">
        <view class="ebtn ebtn-cancel" bindtap="closeEditor">取消</view>
        <view class="ebtn ebtn-save" bindtap="saveProfile">保存</view>
      </view>
    </view>
  </view>
</view>
